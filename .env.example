# FlashDeck environment variables
# Copy this to .env and fill in values, or set them directly in docker-compose.yml

# Path inside the container where SQLite database is stored
# This should match the volume mount in docker-compose.yml
DB_PATH=/data/flashdeck.db

# Directory the server scans when you click "Scan Mounted Folder"
# Mount your notes folder here in docker-compose.yml
CARDS_DIR=/cards

# Anthropic API key — required only for AI resource generation
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
